---
import "../styles/global.css";
---

<header class="md:mt-6">
  <nav class="flex items-center justify-between gap-3 py-3">
    <a
      href="/"
      aria-label="Brian Hennessy home"
      class="inline-flex h-9 w-9 items-center"
    >
      <img src="../../logo/favicon.svg" alt="" class="h-9 w-9" />
    </a>

    <div class="hidden items-center gap-1 md:flex">
      <a
        class="text-secondary hover:text-primary rounded-lg px-4 py-2 text-sm transition-colors"
        href="/">Index</a
      >
      <a
        class="text-secondary hover:text-primary rounded-lg px-4 py-2 text-sm transition-colors"
        href="#writing">Writing</a
      >
      <a
        class="text-secondary hover:text-primary rounded-lg px-4 py-2 text-sm transition-colors"
        href="#projects">Projects</a
      >
    </div>
  </nav>
</header>
